# ---- Site URL (used for SEO, sitemap, and social preview links) ----
# Set this to your live domain once deployed, e.g. https://noambenjamin.com
NEXT_PUBLIC_SITE_URL=https://noambenjamin.com

# ---- Supabase (stores every contact submission) ----
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the service_role key (server-side only, never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Resend (sends the email to your inbox) ----
# Create a free key at https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key

# Where contact messages are delivered (defaults to your CV email)
CONTACT_EMAIL=noambenjamin40@gmail.com

# The "from" address. Until you verify your own domain in Resend,
# you can leave the default below (Resend's shared sender).
CONTACT_FROM=Portfolio Contact <onboarding@resend.dev>
